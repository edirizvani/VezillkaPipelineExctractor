# Copy to .env and fill in. Never commit the real .env or the key file itself.

# Path to your GCP service account JSON key, used by pipeline_v1/scripts/scrape_to_gcs.py
# and pipeline_v1/scripts/reorganize_gcs_months.py to upload PDFs to Cloud Storage.
GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/your-service-account.json
